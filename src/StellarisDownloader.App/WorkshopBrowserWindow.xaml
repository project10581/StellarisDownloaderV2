<Window x:Class="StellarisDownloader.App.WorkshopBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{DynamicResource Browser.Title}"
        Width="1400"
        Height="850"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="RuntimeMissingPanel"
                Visibility="Collapsed"
                Padding="12"
                Margin="0,0,0,10"
                Background="#22D98412"
                BorderBrush="#88D98412"
                BorderThickness="1"
                CornerRadius="4">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Browser.InstallRuntime}"
                        Click="InstallRuntime_Click"
                        Padding="12,6" />
                <TextBlock Text="{DynamicResource Browser.RuntimeMissing}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,12,0" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{DynamicResource Download.Queue}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ListBox x:Name="BrowserQueueList"
                         Grid.Row="1"
                         ItemsSource="{Binding Items}"
                         SelectionMode="Extended"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding DisplayTitle}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding WorkshopId}" Foreground="Gray" />
                                <TextBlock Text="{Binding Status}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                    <Button x:Name="AddCurrentButton"
                            Content="{DynamicResource Browser.AddCurrent}"
                            Click="AddCurrent_Click"
                            IsEnabled="False"
                            Padding="10,6"
                            Margin="0,0,6,6" />
                    <Button Content="{DynamicResource Download.RemoveSelected}"
                            Click="RemoveSelected_Click"
                            Padding="10,6"
                            Margin="0,0,6,6" />
                    <Button Content="{DynamicResource Download.Clear}"
                            Click="ClearQueue_Click"
                            Padding="10,6"
                            Margin="0,0,6,6" />
                    <Button Content="{DynamicResource Download.Start}"
                            Command="{Binding StartCommand}"
                            Padding="10,6"
                            Margin="0,0,6,6" />
                    <Button Content="{DynamicResource Download.Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="10,6"
                            Margin="0,0,6,6" />
                </WrapPanel>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent" />

            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BackButton"
                            Content="{DynamicResource Browser.Back}"
                            Click="Back_Click"
                            IsEnabled="False"
                            Padding="12,6"
                            Margin="0,0,8,0" />
                    <Button x:Name="ForwardButton"
                            Content="{DynamicResource Browser.Forward}"
                            Click="Forward_Click"
                            IsEnabled="False"
                            Padding="12,6"
                            Margin="0,0,8,0" />
                    <Button Content="{DynamicResource Browser.Reload}"
                            Click="Reload_Click"
                            Padding="12,6" />
                </StackPanel>

                <TextBlock x:Name="PageTitleText"
                           Grid.Row="1"
                           Text="{DynamicResource Browser.CurrentPage}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,5" />
                <TextBox x:Name="CurrentUrlText"
                         Grid.Row="2"
                         IsReadOnly="True"
                         Padding="7,5"
                         Margin="0,0,0,8" />

                <Grid Grid.Row="3">
                    <wv2:WebView2 x:Name="WorkshopWebView"
                                 Visibility="Hidden" />
                    <TextBlock x:Name="BrowserStatusText"
                               Text="{DynamicResource Browser.LoadFailed}"
                               Visibility="Collapsed"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Firebrick"
                               TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
