<Window x:Class="StellarisDownloader.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="650"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="22">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                        <Setter Property="IsEnabled" Value="False" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,16"
                   Text="{DynamicResource Settings.Required}"
                   TextWrapping="Wrap"
                   Foreground="#AA5A00">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsInitialization}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,16"
                   Text="{DynamicResource Settings.CorruptBackup}"
                   TextWrapping="Wrap"
                   Foreground="Firebrick">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CorruptBackupPath}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="2"
                   Margin="0,0,0,5"
                   FontWeight="SemiBold"
                   Text="{DynamicResource Settings.LibraryRoot}" />
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding LibraryRoot, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" />
            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Padding="14,6"
                    Content="{DynamicResource Settings.Browse}"
                    Click="BrowseButton_Click" />
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="{DynamicResource Settings.Language}" />
            <ComboBox Grid.Column="1"
                      MinWidth="210"
                      HorizontalAlignment="Left"
                      SelectedValue="{Binding SelectedLanguage}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Tag="en" Content="{DynamicResource Settings.English}" />
                <ComboBoxItem Tag="zh-CN" Content="{DynamicResource Settings.Chinese}" />
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="5" Margin="0,0,0,16">
            <CheckBox Margin="0,4"
                      Content="{DynamicResource Settings.RefreshOnStartup}"
                      IsChecked="{Binding RefreshLibraryOnStartup}" />
            <CheckBox Margin="0,4"
                      Content="{DynamicResource Settings.CheckModsOnStartup}"
                      IsChecked="{Binding CheckModUpdatesOnStartup}" />
            <CheckBox Margin="0,4"
                      Content="{DynamicResource Settings.CheckAppOnStartup}"
                      IsChecked="{Binding CheckAppUpdatesOnStartup}" />
        </StackPanel>

        <TextBlock Grid.Row="6"
                   Margin="0,0,0,14"
                   Foreground="Firebrick"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="90"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Content="{DynamicResource Settings.Cancel}"
                    Click="CancelButton_Click" />
            <Button MinWidth="90"
                    Padding="12,6"
                    IsDefault="True"
                    Content="{DynamicResource Settings.Save}"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
