<Window x:Class="StellarisDownloader.App.UpdateSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Updates.Title}"
        Width="1100"
        Height="650"
        MinWidth="820"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="{DynamicResource Updates.Check}"
                    Command="{Binding CheckUpdatesCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="{DynamicResource Updates.SelectAllAvailable}"
                    Command="{Binding SelectAllAvailableCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="{DynamicResource Updates.DownloadSelected}"
                    Command="{Binding UpdateSelectedCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="{DynamicResource Updates.Cancel}"
                    Command="{Binding CancelCommand}"
                    Padding="12,6" />
        </StackPanel>

        <DataGrid x:Name="UpdateGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{DynamicResource Updates.Selected}" Width="75">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsSelectionEnabled}"
                                      HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{DynamicResource Updates.Mod}"
                                    Binding="{Binding DisplayTitle}"
                                    IsReadOnly="True"
                                    Width="2*" />
                <DataGridTextColumn Header="{DynamicResource Updates.WorkshopId}"
                                    Binding="{Binding WorkshopId}"
                                    IsReadOnly="True"
                                    Width="130" />
                <DataGridTextColumn Header="{DynamicResource Updates.State}"
                                    Binding="{Binding State}"
                                    IsReadOnly="True"
                                    Width="130" />
                <DataGridTextColumn Header="{DynamicResource Updates.RemoteUpdated}"
                                    Binding="{Binding LatestRemoteUpdatedAtUtc, StringFormat={}{0:g}}"
                                    IsReadOnly="True"
                                    Width="170" />
                <DataGridCheckBoxColumn Header="{DynamicResource Updates.Approximate}"
                                        Binding="{Binding UsesApproximateLocalTimestamp, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="145" />
                <DataGridTextColumn Header="{DynamicResource Updates.Error}"
                                    Binding="{Binding Error}"
                                    IsReadOnly="True"
                                    Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding ProgressMessage}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding LastError}"
                       Foreground="Firebrick"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="{DynamicResource Download.ProgressLabel}" />
            <TextBlock Text="{Binding ProgressCompleted}" Margin="4,0,0,0" />
            <TextBlock Text="/" Margin="3,0" />
            <TextBlock Text="{Binding ProgressTotal}" />
            <TextBlock Text="{Binding CurrentWorkshopId}" Margin="12,0,20,0" />
            <TextBlock Text="{DynamicResource Download.SucceededLabel}" />
            <TextBlock Text="{Binding SucceededCount}" Margin="4,0,12,0" />
            <TextBlock Text="{DynamicResource Download.FailedLabel}" />
            <TextBlock Text="{Binding FailedCount}" Margin="4,0,12,0" />
            <TextBlock Text="{DynamicResource Download.CancelledLabel}" />
            <TextBlock Text="{Binding CancelledCount}" Margin="4,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
