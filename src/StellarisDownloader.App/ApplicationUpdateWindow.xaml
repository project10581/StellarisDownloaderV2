<Window x:Class="StellarisDownloader.App.ApplicationUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppUpdates.Title}"
        Width="720"
        Height="520"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{DynamicResource AppUpdates.CurrentVersion}"
                       FontWeight="SemiBold"
                       Margin="0,0,14,8" />
            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentVersion}"
                       Margin="0,0,0,8" />
            <TextBlock Grid.Row="1"
                       Text="{DynamicResource AppUpdates.LatestVersion}"
                       FontWeight="SemiBold"
                       Margin="0,0,14,10" />
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding LatestVersion, TargetNullValue=—}"
                       Margin="0,0,0,10" />
        </Grid>

        <GroupBox Grid.Row="1"
                  Header="{DynamicResource AppUpdates.ReleaseNotes}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="10">
                <TextBlock Text="{Binding ReleaseNotes, TargetNullValue=—}"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </GroupBox>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressPercentage}"
                         Height="16" />
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0,7,0,0"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ProgressMessage}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding LastError}"
                       Margin="0,4,0,0"
                       Foreground="Firebrick"
                       TextWrapping="Wrap" />
        </StackPanel>

        <WrapPanel Grid.Row="3"
                   HorizontalAlignment="Right"
                   Margin="0,14,0,0">
            <Button Content="{DynamicResource AppUpdates.Check}"
                    Command="{Binding CheckCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="{DynamicResource AppUpdates.Download}"
                    Command="{Binding DownloadCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="{DynamicResource AppUpdates.Cancel}"
                    Command="{Binding CancelCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="{DynamicResource AppUpdates.RestartNow}"
                    Command="{Binding ApplyAndRestartCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="{DynamicResource AppUpdates.Later}"
                    IsCancel="True"
                    Padding="12,6" />
        </WrapPanel>
    </Grid>
</Window>
