<Window x:Class="StellarisDownloader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:StellarisDownloader.App.ViewModels"
        mc:Ignorable="d"
        Title="{DynamicResource App.Title}"
        Width="1250"
        Height="760"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,14,0,3" />
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Style="{StaticResource ToolbarButton}"
                    Content="{DynamicResource Command.Settings}"
                    Click="SettingsButton_Click" />
            <Button Style="{StaticResource ToolbarButton}"
                    Content="{DynamicResource Command.Refresh}"
                    Command="{Binding RefreshCommand}" />
            <Button Style="{StaticResource ToolbarButton}"
                    Content="{DynamicResource Command.Rescan}"
                    Command="{Binding RescanCommand}" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                Padding="10,7"
                Background="#11000000"
                CornerRadius="4">
            <Grid>
                <TextBlock Text="{DynamicResource Status.Loading}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static viewModels:LibraryViewState.Loading}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{DynamicResource Status.Ready}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static viewModels:LibraryViewState.Ready}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{DynamicResource Status.NoLibrary}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static viewModels:LibraryViewState.NoLibrary}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{DynamicResource Status.Stale}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static viewModels:LibraryViewState.Stale}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding LastError, TargetNullValue={DynamicResource Status.Error}}"
                           Foreground="Firebrick">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}"
                                             Value="{x:Static viewModels:LibraryViewState.Error}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" MinWidth="380" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="7*" MinWidth="480" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#22000000" BorderThickness="1" CornerRadius="5">
                <Grid Margin="16">
                    <TextBlock Text="{DynamicResource Detail.NoSelection}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Gray">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMod}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedMod}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Border Height="230" Background="#16000000" CornerRadius="4">
                                <Grid>
                                    <TextBlock Text="{DynamicResource Detail.NoSelection}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="Gray" />
                                    <Image Source="{Binding DataContext.PreviewImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.Title}" />
                            <TextBlock Text="{Binding DisplayTitle}" FontSize="20" TextWrapping="Wrap" />

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.Author}" />
                            <TextBlock Text="{Binding Record.CreatorId, TargetNullValue=—}" />

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.Size}" />
                            <TextBlock Text="{Binding Record.FileSize, TargetNullValue=—, StringFormat={}{0:N0} bytes}" />

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.RemoteUpdated}" />
                            <TextBlock Text="{Binding RemoteUpdatedAtUtc, TargetNullValue=—, StringFormat={}{0:g}}" />

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.LastDownloaded}" />
                            <TextBlock Text="{Binding LastDownloadedAtUtc, StringFormat={}{0:g}}" />

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.Workshop}" />
                            <TextBlock Text="{Binding WorkshopUrl}" TextWrapping="Wrap" />

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.LocalPath}" />
                            <TextBlock Text="{Binding Record.ContentPath}" TextWrapping="Wrap" />

                            <TextBlock Style="{StaticResource DetailLabel}"
                                       Text="{DynamicResource Detail.Description}" />
                            <TextBlock Text="{Binding Record.Description, TargetNullValue=—}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent" />

            <Grid Grid.Column="2" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Search.Label}" Margin="0,0,0,4" />
                <TextBox Grid.Row="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         Margin="0,0,0,10" />

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Sort.Label}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox MinWidth="220"
                                  SelectedValue="{Binding SelectedSort}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Tag="{x:Static viewModels:ModSortOption.Title}"
                                          Content="{DynamicResource Sort.Title}" />
                            <ComboBoxItem Tag="{x:Static viewModels:ModSortOption.RemoteUpdated}"
                                          Content="{DynamicResource Sort.RemoteUpdated}" />
                            <ComboBoxItem Tag="{x:Static viewModels:ModSortOption.LastDownloaded}"
                                          Content="{DynamicResource Sort.LastDownloaded}" />
                            <ComboBoxItem Tag="{x:Static viewModels:ModSortOption.FileSize}"
                                          Content="{DynamicResource Sort.FileSize}" />
                        </ComboBox>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ModsView}"
                             SelectedItem="{Binding SelectedMod}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True"
                             BorderBrush="#22000000"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:ModListItemViewModel}">
                                <TextBlock Text="{Binding DisplayTitle}"
                                           Padding="8,6"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
